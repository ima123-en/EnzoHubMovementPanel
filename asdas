local function setupDeathListener()
    local ch = LocalPlayer.Character
    if ch then
        local h = ch:FindFirstChildOfClass("Humanoid")
        if h then
            h.Died:Connect(function()
                clearAllGhosts()
                lagbackCallCount = 0
                if animPlaying then
                    task.spawn(turnOff)
                end
            end)
        end
    end
end

