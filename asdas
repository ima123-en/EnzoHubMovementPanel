            TweenService:Create(knob, TweenInfo.new(0.1), {Position = UDim2.new(0, px - 5, 0.5, -5)}):Play()
        end
    end

    local function updateFromX(px)
        local origin = barBack.AbsolutePosition.X
        local len = barBack.AbsoluteSize.X
        if len <= 0 then return end
        local alpha = (px - origin) / len
        setFromAlpha(alpha, false)
    end

    AddConn(barBack.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            isInteractingWithSlider = true
            updateFromX(i.Position.X)
        end
    end))

    AddConn(knob.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            isInteractingWithSlider = true
        end
    end))

    AddConn(UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(i.Position.X)
        end
    end))

    AddConn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            if dragging then
                dragging = false
                isInteractingWithSlider = false
            end
        end
    end))

    task.defer(function()
        local v = getVal()
        local alpha = (v - minVal) / (maxVal - minVal)
        setFromAlpha(alpha, true)
    end)
end

