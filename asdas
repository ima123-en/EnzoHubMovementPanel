local function setGuiAlpha(a, instant)
    a = math.clamp(a, 0, 1)
    local value = math.floor(20 + (100 - 20) * a + 0.5)
    _G.InvisGuiScale = value
    local len = guiBar.AbsoluteSize.X
    if len > 0 then
        local px = a * len
        if instant then
            guiFill.Size = UDim2.new(0, px, 1, 0)
            guiKnob.Position = UDim2.new(0, px - 5, 0.5, -5)
        else
            TweenService:Create(guiFill, TweenInfo.new(0.1), {Size = UDim2.new(0, px, 1, 0)}):Play()
            TweenService:Create(guiKnob, TweenInfo.new(0.1), {Position = UDim2.new(0, px - 5, 0.5, -5)}):Play()
        end
    end
    local scale = 0.3 + (1.0 - 0.3) * ((value - 20) / (100 - 20))
    if instant then
        GlobalUIScale.Scale = scale
    else
        TweenService:Create(GlobalUIScale, TweenInfo.new(0.15), {Scale = scale}):Play()
    end
    SaveSettings()
end

