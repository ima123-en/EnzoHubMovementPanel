local SAVE_KEY = "InvisSteal_Settings_" .. LocalPlayer.UserId

local function SaveSettings()
    pcall(function()
        if writefile then
            writefile(SAVE_KEY .. ".json", HttpService:JSONEncode({
                InvisStealAngle = _G.InvisStealAngle,
                SinkSliderValue = _G.SinkSliderValue,
                AutoRecoverLagback = _G.AutoRecoverLagback,
                AutoInvisDuringSteal = _G.AutoInvisDuringSteal,
                INVISIBLE_STEAL_KEY = _G.INVISIBLE_STEAL_KEY,
                FLOAT_KEY = _G.FLOAT_KEY,
                InvisGuiScale = _G.InvisGuiScale
            }))
        end
    end)
end

local function LoadSettings()
    pcall(function()
        if readfile and isfile and isfile(SAVE_KEY .. ".json") then
            local data = HttpService:JSONDecode(readfile(SAVE_KEY .. ".json"))
            if data.InvisStealAngle then _G.InvisStealAngle = data.InvisStealAngle end
            if data.SinkSliderValue then _G.SinkSliderValue = data.SinkSliderValue end
            if data.AutoRecoverLagback ~= nil then _G.AutoRecoverLagback = data.AutoRecoverLagback end
            if data.AutoInvisDuringSteal ~= nil then _G.AutoInvisDuringSteal = data.AutoInvisDuringSteal end
            if data.INVISIBLE_STEAL_KEY then _G.INVISIBLE_STEAL_KEY = data.INVISIBLE_STEAL_KEY end
            if data.FLOAT_KEY then _G.FLOAT_KEY = data.FLOAT_KEY end
            if data.InvisGuiScale ~= nil then _G.InvisGuiScale = data.InvisGuiScale end
        end
    end)
end

