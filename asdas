    btnLabel.TextColor3 = stateRef.value and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(200, 80, 80)
    btnLabel.Parent = btn

    local function update(state, instant)
        stateRef.value = state
        local textCol = state and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(200, 80, 80)
        local bgCol = state and Color3.fromRGB(40, 40, 40) or Color3.fromRGB(25, 25, 25)
        btnLabel.Text = state and "ON" or "OFF"
        if instant then
            btnLabel.TextColor3 = textCol
            btn.BackgroundColor3 = bgCol
        else
            TweenService:Create(btnLabel, TweenInfo.new(0.15), {TextColor3 = textCol}):Play()
            TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = bgCol}):Play()
        end
