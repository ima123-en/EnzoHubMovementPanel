local draggingPanel = false
local dragStart
local startPos

DragBar.InputBegan:Connect(function(i)
    if isInteractingWithSlider then return end
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        draggingPanel = true
        dragStart = i.Position
        startPos = Main.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingPanel and not isInteractingWithSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        draggingPanel = false
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if _G.WaitingForInvisKey and input.UserInputType == Enum.UserInputType.Keyboard then
        _G.WaitingForInvisKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            _G.INVISIBLE_STEAL_KEY = keyName
            if _G.InvisKeyButton then _G.InvisKeyButton.Text = keyName end
            SaveSettings()
        else
            if _G.InvisKeyButton then _G.InvisKeyButton.Text = _G.INVISIBLE_STEAL_KEY end
        end
        return
    end

    if _G.WaitingForFloatKey and input.UserInputType == Enum.UserInputType.Keyboard then
        _G.WaitingForFloatKey = false
        local keyName = input.KeyCode.Name
        if keyName and keyName ~= "Unknown" then
            _G.FLOAT_KEY = keyName
            if _G.FloatKeyButton then _G.FloatKeyButton.Text = keyName end
            SaveSettings()
        else
            if _G.FloatKeyButton then _G.FloatKeyButton.Text = _G.FLOAT_KEY end
        end
        return
    end

    if input.UserInputType == Enum.UserInputType.Keyboard then
        local invisKeyCode = Enum.KeyCode[_G.INVISIBLE_STEAL_KEY]
        if invisKeyCode and input.KeyCode == invisKeyCode then
            pcall(_G.toggleInvisibleSteal)
            enabledRowUpdate(_G.invisibleStealEnabled, false)
            return
        end

        local floatKeyCode = Enum.KeyCode[_G.FLOAT_KEY]
        if floatKeyCode and input.KeyCode == floatKeyCode then
            FloatEnabled = not FloatEnabled
            if _G.UpdateFloatButton then
                _G.UpdateFloatButton(FloatEnabled, false)
            end
            if FloatEnabled then
                StartFloat()
            else
                StopFloat()
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.2) do
        if not movementToggleState or not rootGui or not rootGui.Parent then
            turnOff()
            StopFloat()
            ScreenGui:Destroy()
            script:Destroy()
            break
        end
        local mainWindow = rootGui:FindFirstChild("MainWindow")
        if not mainWindow then
            movementToggleState = false
        else
            local cf = mainWindow:FindFirstChild("ContentFrame") or mainWindow
            local uiPage = nil
            for _, f in ipairs(cf:GetChildren()) do
                if f:IsA("Frame") and f.Name == "UIPage" then
                    uiPage = f
                    break
                end
            end
            if uiPage then
                local found = false
                for _, child in ipairs(uiPage:GetChildren()) do
                    if child:IsA("Frame") then
                        local label = child:FindFirstChildWhichIsA("TextLabel")
                        local btn = child:FindFirstChildWhichIsA("TextButton")
                        if label and btn and label.Text == "Movement Panel" then
                            local bg = btn.BackgroundColor3
                            found = true
                            movementToggleState = not (bg.R == 60/255 and bg.G == 60/255 and bg.B == 60/255)
                            break
                        end
                    end
                end
                if not found then
                    movementToggleState = false
                end
            else
                movementToggleState = false
            end
        end
        if not movementToggleState then
            turnOff()
            StopFloat()
            ScreenGui:Destroy()
            script:Destroy()
            break
        end
    end
end)

