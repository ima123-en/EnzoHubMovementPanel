local function clearAllGhosts()
    lagbackCallCount = 0
    lastLagbackTime = 0
end

local function createServerGhost(position)
    local now = tick()
    if now - lastLagbackTime < 0.15 then return end
    lastLagbackTime = now
    if now - lagbackWindowStart > 3 then
        lagbackCallCount = 0
        lagbackWindowStart = now
    end
    lagbackCallCount = lagbackCallCount + 1
    if lagbackCallCount >= 15 then
        if _G.toggleInvisibleSteal and _G.invisibleStealEnabled then
            task.spawn(function()
                pcall(_G.toggleInvisibleSteal)
            end)
        end
        lagbackCallCount = 0
        return
    end
end

